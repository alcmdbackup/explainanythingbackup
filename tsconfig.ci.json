{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "incremental": true,
    "tsBuildInfoFile": "tsconfig.ci.tsbuildinfo"
  },
  "include": ["next-env.d.ts", "src/**/*.ts", "src/**/*.tsx", "evolution/src/**/*.ts", "evolution/src/**/*.tsx", "evolution/scripts/*.ts", "evolution/scripts/lib/**/*.ts", "scripts/**/*.ts"],
  "exclude": [
    "node_modules",
    ".next",
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/*.spec.ts",
    "**/*.spec.tsx",
    "**/__tests__/**",
    "evolution/scripts/deferred/**"
  ]
}
