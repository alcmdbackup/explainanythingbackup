#!/usr/bin/env bash
# Pre-commit checks: secret scanning + migration timestamp validation.
# Bypass with: git commit --no-verify

set -euo pipefail

# --- Secret scanning: block commits containing passwords, API keys, tokens ---
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM 2>/dev/null || true)
if [ -n "$STAGED_FILES" ]; then
  SECRET_PATTERNS='(password|passwd|api_key|apikey|secret_key|access_token|auth_token|private_key)[[:space:]]*[:=][[:space:]]*["\x27][^"\x27]{4,}'
  FOUND_SECRETS=false
  while IFS= read -r file; do
    [ -z "$file" ] && continue
    # Skip binary files and .env.example
    [[ "$file" == *.example ]] && continue
    # Check staged content (not working directory)
    if git show ":$file" 2>/dev/null | grep -iqE "$SECRET_PATTERNS"; then
      if [ "$FOUND_SECRETS" = false ]; then
        echo ""
        echo "ERROR: Potential secrets detected in staged files:"
        FOUND_SECRETS=true
      fi
      echo "  $file"
    fi
  done <<< "$STAGED_FILES"
  if [ "$FOUND_SECRETS" = true ]; then
    echo ""
    echo "Remove secrets before committing, or bypass: git commit --no-verify"
    echo ""
    exit 1
  fi
fi

# --- Evolution TypeScript enforcement: block @ts-ignore, @ts-nocheck, as any ---
EVOLUTION_STAGED=$(git diff --cached --name-only --diff-filter=ACM | grep "^evolution/src/" | grep -v '\.test\.\|\.spec\.\|/testing/' || true)

if [ -n "$EVOLUTION_STAGED" ]; then
  TS_VIOLATIONS=""
  while IFS= read -r file; do
    [ -z "$file" ] && continue
    MATCHES=$(git show ":$file" 2>/dev/null | grep -nE '@ts-ignore|@ts-nocheck|\bas[[:space:]]+any\b' || true)
    if [ -n "$MATCHES" ]; then
      if [ -z "$TS_VIOLATIONS" ]; then
        echo ""
        echo "ERROR: TypeScript anti-patterns in evolution/ production code:"
      fi
      TS_VIOLATIONS="found"
      echo "  $file"
      echo "$MATCHES" | sed 's/^/    /'
    fi
  done <<< "$EVOLUTION_STAGED"

  if [ -n "$TS_VIOLATIONS" ]; then
    echo ""
    echo "Remove @ts-ignore, @ts-nocheck, and 'as any' before committing."
    echo "Use proper types or // eslint-disable-next-line with justification."
    echo "Bypass: git commit --no-verify"
    echo ""
    exit 1
  fi
fi

# --- Migration timestamp validation ---
STAGED_MIGRATIONS=$(git diff --cached --name-only --diff-filter=A -- 'supabase/migrations/*.sql' || true)

if [ -z "$STAGED_MIGRATIONS" ]; then
  exit 0
fi

# Fetch latest main quietly (skip if offline)
git fetch origin main --quiet 2>/dev/null || true

LATEST_ON_MAIN=$(git ls-tree origin/main --name-only supabase/migrations/ 2>/dev/null \
  | xargs -I{} basename {} \
  | grep -oE '^[0-9]{14}' \
  | sort -n \
  | tail -1)

if [ -z "$LATEST_ON_MAIN" ]; then
  exit 0
fi

BLOCKED=false

while IFS= read -r file; do
  BASENAME=$(basename "$file")
  FILE_TS=$(echo "$BASENAME" | grep -oE '^[0-9]{14}' || true)

  if [ -z "$FILE_TS" ]; then
    continue
  fi

  if [ "$FILE_TS" -le "$LATEST_ON_MAIN" ]; then
    if [ "$BLOCKED" = false ]; then
      echo ""
      echo "ERROR: Migration timestamp(s) conflict with main"
      echo "Latest on main: $LATEST_ON_MAIN"
      echo ""
      BLOCKED=true
    fi
    NEXT_TS=$((LATEST_ON_MAIN + 1))
    DESCRIPTION=$(echo "$BASENAME" | sed "s/^${FILE_TS}_//")
    echo "  $file"
    echo "    Fix: git mv $file supabase/migrations/${NEXT_TS}_${DESCRIPTION}"
    LATEST_ON_MAIN=$NEXT_TS
  fi
done <<< "$STAGED_MIGRATIONS"

if [ "$BLOCKED" = true ]; then
  echo ""
  echo "Bypass: git commit --no-verify"
  echo "(The CI auto-rename Action will also fix this in your PR)"
  echo ""
  exit 1
fi

# Check for duplicate migration versions (across all files, not just staged)
ALL_TIMESTAMPS=$(ls supabase/migrations/*.sql 2>/dev/null \
  | xargs -I{} basename {} \
  | grep -oE '^[0-9]{14}' \
  | sort)

if [ -n "$ALL_TIMESTAMPS" ]; then
  DUPES=$(echo "$ALL_TIMESTAMPS" | uniq -d)

  if [ -n "$DUPES" ]; then
    echo ""
    echo "ERROR: Duplicate migration version(s) detected:"
    while IFS= read -r ts; do
      [ -z "$ts" ] && continue
      echo "  Version $ts:"
      ls supabase/migrations/"${ts}"_* 2>/dev/null | sed 's/^/    /'
    done <<< "$DUPES"
    echo ""
    echo "Bypass: git commit --no-verify"
    echo ""
    exit 1
  fi
fi
