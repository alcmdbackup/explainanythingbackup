# ===========================================
# ExplainAnything Environment Configuration
# ===========================================
# Copy this file to .env.local and fill in values
# See docs/docs_overall/environments.md for details

# --- Supabase ---
# Get these from: https://supabase.com/dashboard/project/YOUR_PROJECT/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- AI Services ---
# OpenAI: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# DeepSeek: https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# Anthropic: https://console.anthropic.com/settings/keys
# Optional — only required when using claude-* models
ANTHROPIC_API_KEY=

# OpenRouter: https://openrouter.ai/keys
# Optional — only required when using openai/gpt-oss-20b model
OPENROUTER_API_KEY=

# Pinecone: https://app.pinecone.io
PINECONE_API_KEY=
PINECONE_INDEX_NAME_ALL=explainanythingdevlarge

# --- Observability (Honeycomb) ---
# Get API key from: https://ui.honeycomb.io → Team Settings → API Keys
# Create an Ingest key with "Can create datasets" permission
# NOTE: x-honeycomb-dataset is required - data will go to this dataset in Honeycomb
OTEL_EXPORTER_OTLP_ENDPOINT=https://api.honeycomb.io
OTEL_EXPORTER_OTLP_HEADERS=x-honeycomb-team=YOUR_HONEYCOMB_API_KEY,x-honeycomb-dataset=explainanything
OTEL_SERVICE_NAME=explainanything

# Browser tracing (goes through /api/traces proxy, no client-side key needed)
NEXT_PUBLIC_ENABLE_BROWSER_TRACING=false

# --- Log Levels (optional) ---
# Server-side (runtime): Send all log levels (debug/info) to Honeycomb, not just error/warn
# WARNING: Enabling this can consume significant event budget (20M/month free tier)
OTEL_SEND_ALL_LOG_LEVELS=false

# Client-side (BUILD-TIME): Client sends all log levels to server
# NOTE: Changing this requires a new deployment (not just env var update)
NEXT_PUBLIC_LOG_ALL_LEVELS=false

# --- Sentry (optional) ---
# Leave blank to disable error tracking
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# --- E2E Testing (optional) ---
# Only needed if running E2E tests locally
TEST_USER_EMAIL=
TEST_USER_PASSWORD=
TEST_USER_ID=
PINECONE_NAMESPACE=
NEXT_PUBLIC_USE_AI_API_ROUTE=true

# --- Demo Mode (optional) ---
# When 'true', linkResolver merges approved candidates from link_candidates into the
# whitelist on render so AI-suggested terms link inline without admin approval. The
# whitelist + candidate-approval admin code remains intact. See
# docs/feature_deep_dives/link_whitelist_system.md.
LINKS_BYPASS_WHITELIST=false

# Guest account for public-site auto-login (Phase 5 of demo prep).
# Provision via `npx tsx scripts/seed-guest-user.ts` against the target Supabase
# project — captures GUEST_USER_ID and prints GUEST_PASSWORD once.
# Set in: Vercel Production + Preview env vars, GitHub Actions staging + Production env secrets.
# Leave blank to disable auto-login (middleware will fall back to /login redirect).
GUEST_EMAIL=
GUEST_PASSWORD=
GUEST_USER_ID=
# Client-side hook (useIsGuest) reads NEXT_PUBLIC_GUEST_EMAIL. Bundled at build time.
NEXT_PUBLIC_GUEST_EMAIL=

# Per-user LLM cap bypass for seed scripts (e.g., scripts/seed-guest-library.ts).
# When 'true', LlmSpendingGate.checkPerUserCap() returns immediately even for the
# guest user. Set ONLY when running the seed script; NEVER set in any deployed env.
SEED_BYPASS_USER_CAP=false

# --- Development Performance Mode ---
# Disables Sentry, OpenTelemetry, logging wrappers for faster local dev
# NEVER enable in production (has explicit runtime guard that logs error and skips)
# Set both for server and client-side observability to be disabled
FAST_DEV=
NEXT_PUBLIC_FAST_DEV=
